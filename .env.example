########################################
# Backend & Database configuration
########################################

# Postgres settings (used by docker-compose and backend)
POSTGRES_DB=astro_db
POSTGRES_USER=astro_user
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_PORT=5432

# Host used by the backend to reach Postgres when running in Docker
POSTGRES_SERVER=db

########################################
# Frontend configuration
########################################

# Base URL for the FastAPI backend as seen from the browser
VITE_API_URL=http://localhost:8000

